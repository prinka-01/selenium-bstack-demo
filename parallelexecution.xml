<suite name="Cross Browser Suite"
       parallel="tests"
       thread-count="3">
       
       <!-- CHROME -->
    <test name="Chrome Tests">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.bstackdemo.automation.tests.LoginTest"/>
            <class name="com.bstackdemo.automation.tests.ProductPageTest"/>
            <class name="com.bstackdemo.automation.tests.CartTest"/>
            <class name="com.bstackdemo.automation.tests.CheckoutTest"/>
        </classes>
    </test>

    <!-- FIREFOX -->
    <test name="Firefox Tests">
        <parameter name="browser" value="firefox"/>
        <classes>
            <class name="com.bstackdemo.automation.tests.LoginTest"/>
            <class name="com.bstackdemo.automation.tests.ProductPageTest"/>
            <class name="com.bstackdemo.automation.tests.CartTest"/>
            <class name="com.bstackdemo.automation.tests.CheckoutTest"/>
        </classes>
    </test>

    <!-- EDGE -->
    <test name="Edge Tests">
        <parameter name="browser" value="edge"/>
        <classes>
            <class name="com.bstackdemo.automation.tests.LoginTest"/>
            <class name="com.bstackdemo.automation.tests.ProductPageTest"/>
            <class name="com.bstackdemo.automation.tests.CartTest"/>
            <class name="com.bstackdemo.automation.tests.CheckoutTest"/>
        </classes>
    </test>
</suite>
